# AudioVerse Environment Variables
# Copy this to .env and fill in your values

# Google Analytics (optional)
VITE_GA_ID=

# Google AdSense (optional)
VITE_ADSENSE_CLIENT_ID=

# Future: API endpoint
VITE_API_URL=

# Future: Firebase/Supabase
VITE_FIREBASE_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Publisher signup app (audioverse-publishers sidecar)
# Dev default: http://localhost:3001
# Prod: https://publishers.audioverse.com
VITE_PUBLISHER_URL=
